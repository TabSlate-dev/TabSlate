VITE_API_URL=http://localhost:8080
# Prosopo site key — leave empty to disable captcha in dev.
VITE_PROSOPO_SITE_KEY=
# Self-hosted Prosopo server URL — leave empty to use official CDN (https://js.prosopo.io).
# VITE_PROSOPO_SERVER_URL=https://your-prosopo-server.example.com
# VITE_PROSOPO_CAPTCHA_TYPE=pow

# OpenAds API URL for homepage carousel and sidebar ads.
VITE_OPENADS_API_URL=https://openads

# Ads Tier IDs
VITE_OPENADS_HOMEPAGE_TIER_ID=
VITE_OPENADS_SIDEBAR_TIER_ID=

VITE_OPENPANEL_URL=https://your-openpanel.com
VITE_OPENPANEL_CLIENT_ID=your-client-id
